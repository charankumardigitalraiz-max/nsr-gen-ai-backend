{
  "name": "nsr-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared Node.js API for NSR website and admin dashboard",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed/seed.js",
    "seed:website": "node src/seed/seedWebsiteContent.js --force",
    "migrate:images": "node src/seed/migrateWebsiteImages.js",
    "migrate:images:db": "node src/seed/migrateWebsiteImages.js --update-db"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
