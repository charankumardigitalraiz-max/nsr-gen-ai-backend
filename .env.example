PORT=5002
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/nsr-gen-ai
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=nsr@admin123
# Comma-separated frontend URLs (required on Render for CORS)
CLIENT_URLS=http://localhost:5173,http://localhost:5174,https://nsr-gen-ai-admin.vercel.app
# All CMS images stored here on the API server (not in the frontend deploy)
UPLOAD_DIR=uploads
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
MAX_UPLOAD_SIZE_MB=10
